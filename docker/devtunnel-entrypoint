#!/usr/bin/env bash
set -euo pipefail

show_help() {
    cat <<'EOF'
DevTunnel Toolkit helper

Usage:
  login [microsoft|github]      Login with device-code flow
  microsoft-login               Login with Microsoft/Entra ID device-code flow
  github-login                  Login with GitHub device-code flow
  logout                        Clear the cached login
  status                        Show current login status
  auth-check                    Verify cached login or access-token auth
  host [devtunnel args...]      Host a tunnel using PORTS/TUNNEL_ID env defaults
  connect [TUNNEL_ID] [args...] Connect to a tunnel
  raw <devtunnel args...>       Run the devtunnel CLI directly

Environment:
  LOGIN_PROVIDER=microsoft|github Provider used by bare "login"
  DEVTUNNEL_ACCESS_TOKEN        Token passed to host/connect as --access-token
  PORTS=3140,53194              Local ports to expose when -p/--port is omitted
  TUNNEL_ID=my-tunnel           Existing tunnel id to host/connect
  ALLOW_ANONYMOUS=true          Add --allow-anonymous
  PROTOCOL=http|https|auto      Add --protocol
  EXPIRATION=2d                 Add --expiration
  VERBOSE=true                  Add --verbose

Examples:
  login microsoft
  login github
  host
  PORTS=3140,53194 ALLOW_ANONYMOUS=true host
  connect my-tunnel
  raw user show
EOF
}

is_true() {
    case "${1:-}" in
        1|true|TRUE|yes|YES|on|ON) return 0 ;;
        *) return 1 ;;
    esac
}

has_port_argument() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            -p|--port|--port=*|--port-number|--port-number=*|--port-numbers|--port-numbers=*) return 0 ;;
        esac
    done
    return 1
}

has_access_token_argument() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            -t|--access-token|--access-token=*) return 0 ;;
        esac
    done
    return 1
}

has_help_argument() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            -h|--help|-\?) return 0 ;;
        esac
    done
    return 1
}

access_token_value() {
    printf '%s' "${DEVTUNNEL_ACCESS_TOKEN:-}"
}

has_cached_login() {
    local output

    if ! output="$(devtunnel user show --json 2>&1)"; then
        printf '%s\n' "$output" >&2
        return 1
    fi

    if printf '%s\n' "$output" | grep -qi '"status"[[:space:]]*:[[:space:]]*"Not logged in"'; then
        return 1
    fi

    return 0
}

cached_login_check_command() {
    if has_cached_login; then
        devtunnel user show
        return 0
    fi

    cat >&2 <<'EOF'
DevTunnel login was not found in this container volume.

Run one of these commands and complete the device-code flow:
  make login-github
  make login-microsoft

Then verify it with:
  make status

If you ran "make reset" or "docker compose down --volumes", the cached login was removed.
EOF
    return 3
}

auth_check_command() {
    local access_token
    access_token="$(access_token_value)"

    if [[ -n "$access_token" ]]; then
        echo "Using DEVTUNNEL_ACCESS_TOKEN for DevTunnel authentication."
        return 0
    fi

    cached_login_check_command
}

host_command() {
    shift

    local args=("host")
    local access_token
    local port
    local ports="${PORTS:-${PORT:-3140,53194}}"

    if ! has_access_token_argument "$@"; then
        access_token="$(access_token_value)"
        if [[ -n "$access_token" ]]; then
            args+=("--access-token" "$access_token")
        else
            auth_check_command >/dev/null
        fi
    fi

    if [[ -n "${TUNNEL_ID:-}" ]]; then
        args+=("${TUNNEL_ID}")
    fi

    if ! has_port_argument "$@"; then
        ports="${ports//,/ }"
        for port in $ports; do
            args+=("-p" "$port")
        done
    fi

    if [[ -n "${PROTOCOL:-}" ]]; then
        args+=("--protocol" "$PROTOCOL")
    fi

    if [[ -n "${EXPIRATION:-}" ]]; then
        args+=("--expiration" "$EXPIRATION")
    fi

    if is_true "${ALLOW_ANONYMOUS:-false}" || is_true "${ANONYMOUS:-false}"; then
        args+=("--allow-anonymous")
    fi

    if is_true "${VERBOSE:-false}"; then
        args+=("--verbose")
    fi

    exec devtunnel "${args[@]}" "$@"
}

connect_command() {
    shift

    local args=("connect")
    local access_token

    if ! has_access_token_argument "$@"; then
        access_token="$(access_token_value)"
        if [[ -n "$access_token" ]]; then
            args+=("--access-token" "$access_token")
        else
            auth_check_command >/dev/null
        fi
    fi

    if [[ -n "${TUNNEL_ID:-}" ]]; then
        args+=("${TUNNEL_ID}")
    elif [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
        args+=("$1")
        shift
    fi

    exec devtunnel "${args[@]}" "$@"
}

login_command() {
    shift

    local provider="${LOGIN_PROVIDER:-microsoft}"

    case "${1:-}" in
        microsoft|ms|entra|aad)
            provider="microsoft"
            shift
            ;;
        github|gh)
            provider="github"
            shift
            ;;
        --github|-g)
            provider="github"
            shift
            ;;
        --microsoft|--entra|--aad)
            provider="microsoft"
            shift
            ;;
        "")
            ;;
        -*)
            ;;
        *)
            echo "Unsupported login provider: $1" >&2
            echo "Use: login microsoft or login github" >&2
            exit 2
            ;;
    esac

    case "$provider" in
        microsoft|ms|entra|aad)
            if has_help_argument "$@"; then
                exec devtunnel user login -e -d "$@"
            fi
            devtunnel user login -e -d "$@"
            ;;
        github|gh)
            if has_help_argument "$@"; then
                exec devtunnel user login -g -d "$@"
            fi
            devtunnel user login -g -d "$@"
            ;;
        *)
            echo "Unsupported login provider: $provider" >&2
            echo "Use: login microsoft or login github" >&2
            exit 2
            ;;
    esac

    echo
    echo "Checking cached login..."
    cached_login_check_command
}

case "${1:-help}" in
    ""|help|--help|-h)
        show_help
        ;;
    login)
        login_command "$@"
        ;;
    microsoft-login|login-microsoft)
        shift
        login_command login microsoft "$@"
        ;;
    github-login|login-github)
        shift
        login_command login github "$@"
        ;;
    logout)
        shift
        exec devtunnel user logout "$@"
        ;;
    status)
        shift
        exec devtunnel user show "$@"
        ;;
    auth-check)
        shift
        auth_check_command "$@"
        ;;
    host)
        host_command "$@"
        ;;
    connect)
        connect_command "$@"
        ;;
    raw)
        shift
        exec devtunnel "$@"
        ;;
    *)
        exec devtunnel "$@"
        ;;
esac
